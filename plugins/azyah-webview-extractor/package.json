{
  "name": "azyah-webview-extractor",
  "version": "1.0.0",
  "description": "Custom Capacitor plugin for in-session product extraction using real WebView with JS injection",
  "main": "dist/esm/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "files": [
    "dist/",
    "ios/",
    "android/"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist"
  },
  "keywords": [
    "capacitor",
    "plugin",
    "webview",
    "extraction"
  ],
  "capacitor": {
    "ios": {
      "src": "ios"
    },
    "android": {
      "src": "android"
    }
  },
  "peerDependencies": {
    "@capacitor/core": "^7.0.0"
  },
  "devDependencies": {
    "@capacitor/core": "^7.4.4",
    "typescript": "^5.0.0",
    "rimraf": "^5.0.0"
  }
}
